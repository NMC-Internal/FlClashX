{
  "_comment": "Copy to env.local.json (gitignored) and fill in. Run: fvm flutter run -d macos --dart-define-from-file=env.local.json",

  "BACKEND_URL": "http://127.0.0.1:8080",

  "_google_comment": "OAuth client IDs from Google Cloud Console (ADR 0014).",
  "GOOGLE_SERVER_CLIENT_ID": "<web-client-id>  (mobile: token audience)",
  "GOOGLE_DESKTOP_CLIENT_ID": "<desktop-client-id>  (macOS/Windows/Linux loopback)",
  "GOOGLE_DESKTOP_CLIENT_SECRET": "<desktop-client-secret>  (only if using client-side exchange)"
}
