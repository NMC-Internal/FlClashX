{
  "_comment": "Copy to env.local.json (gitignored) and fill in. Run: fvm flutter run -d macos --dart-define-from-file=env.local.json",

  "BACKEND_URL": "http://127.0.0.1:8080",

  "_google_comment": "OAuth client IDs from Google Cloud Console (ADR 0014). No secret here — the desktop client secret lives only in go-backend/.env (GOOGLE_DESKTOP_CLIENT_SECRET). Client IDs are public, not secrets.",
  "GOOGLE_SERVER_CLIENT_ID": "<web-client-id>  (Android/iOS/macOS: token audience)",
  "GOOGLE_IOS_CLIENT_ID": "<ios-client-id>  (iOS/macOS native SDK config; required to sign in on macOS)",
  "GOOGLE_DESKTOP_CLIENT_ID": "<desktop-client-id>  (Windows/Linux browser flow)"
}
